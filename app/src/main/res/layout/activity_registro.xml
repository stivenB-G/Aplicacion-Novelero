<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    tools:context=".ui.auth.RegisterActivity">

    <!-- Logo y Cabecera -->
    <LinearLayout
        android:id="@+id/ll_cabecera_registro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logosplash"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.1"
            android:text="@string/titulo_app"
            android:textColor="@color/novelero_accent"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.2"
            android:text="@string/titulo_registro"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Formulario de Registro -->
    <LinearLayout
        android:id="@+id/contenedor_registro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/fondo_cuadro_inicio"
        android:orientation="vertical"
        android:padding="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_cabecera_registro">

        <!-- Nombre de Usuario -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nombre_usuario"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_nombre_usuario"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="@string/hint_usuario"
            android:inputType="textPersonName"
            android:autofillHints="username"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="15sp" />

        <!-- Correo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/correo_electronico"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_correo_registro"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="@string/hint_correo"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="15sp" />

        <!-- Contraseña -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/contrasena"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_contrasena_registro"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="@string/hint_contrasena"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="15sp" />

        <!-- Botón Crear Cuenta -->
        <Button
            android:id="@+id/btn_crear_cuenta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/fondo_boton_principal"
            android:text="@string/btn_crear_cuenta"
            android:textAllCaps="false"
            android:textColor="@color/novelero_bg"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pregunta_login"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_ir_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/btn_iniciar_sesion"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
