<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    tools:context=".ui.auth.RegisterActivity">

    <!-- Cabecera de registro-->
    <LinearLayout
        android:id="@+id/ll_cabecera_registro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/fondo_boton_principal"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registro en Novelero"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.1"
            android:text="COMIENZA TU PROXIMA GRAN AVENTURA"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>


    <!-- Formulario de registro -->
    <LinearLayout
        android:id="@+id/contenedor_registro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_cabecera_registro">

        <!-- Nombre de usuario -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOMBRE DE USUARIO"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/et_nombre_usuario"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="p. ej. LectorNocturno"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="15sp" />


        <!-- Correo electronico -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="CORREO ELECTRONICO"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/et_correo_registro"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="tu@email.com"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="15sp"/>

        <!-- Contraseña-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="CONTRASEÑA"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/et_contrasena_registro"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="••••••••"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="17sp"/>

        <!-- Boton crear cuenta-->
        <Button
            android:id="@+id/btn_crear_cuenta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/fondo_boton_principal"
            android:text="Crear cuenta"
            android:textAllCaps="false"
            android:textColor="@color/novelero_bg"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null"/>

    </LinearLayout>

    <!-- Footer para volver al login-->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Ya tienes una cuenta? "
            android:textColor="@color/novelero_text_secondary"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_ir_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:text="Iniciar Sesión"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
