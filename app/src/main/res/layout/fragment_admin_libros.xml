<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de Novelas"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <!-- SUB -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Administra novelas, publicaciones y contenido."
            android:textColor="@color/novelero_text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <!-- BOTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_novel"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:text="Agregar nueva novela"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:backgroundTint="@color/novelero_primary"
            app:cornerRadius="18dp"/>

        <!-- CARD NOVELA -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/novelero_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp">

                <!-- PORTADA -->
                <View
                    android:layout_width="90dp"
                    android:layout_height="120dp"
                    android:background="@color/novelero_primary"/>

                <!-- INFO -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="18dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sombras del Reino"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Autor: Diana Jimenez"
                        android:textColor="@color/novelero_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ventas: 240"
                        android:textColor="@color/novelero_accent"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp"/>

                    <!-- BOTONES -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <com.google.android.material.button.MaterialButton
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="Editar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/novelero_primary"
                            app:cornerRadius="14dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            android:text="Eliminar"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/novelero_danger"
                            app:cornerRadius="14dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>