<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    tools:context=".ui.auth.LoginActivity">

    <!-- Logo y Cabecera -->
    <LinearLayout
        android:id="@+id/ll_cabecera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logosplash"
            android:contentDescription="Logo Novelero" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.1"
            android:text="NOVELERO"
            android:textColor="@color/novelero_accent"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.2"
            android:text="LECTURA CONTINUA"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Formulario (Movido más abajo) -->
    <LinearLayout
        android:id="@+id/contenedor_login"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="50dp"
        android:background="@drawable/fondo_cuadro_inicio"
        android:orientation="vertical"
        android:padding="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_cabecera">

        <!-- Correo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correo Electrónico"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/et_correo"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="tu@email.com"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="15sp" />

        <!-- Contraseña -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="Contraseña"
                android:textColor="@color/novelero_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_olvide_contrasena"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:clickable="true"
                android:focusable="true"
                android:text="¿Olvidaste tu contraseña?"
                android:textColor="@color/novelero_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <EditText
            android:id="@+id/et_contrasena"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/fondo_campo_texto"
            android:hint="••••••••"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"
            android:textSize="15sp" />

        <!-- Botón -->
        <Button
            android:id="@+id/btn_iniciar_sesion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/fondo_boton_principal"
            android:text="Iniciar Sesión"
            android:textAllCaps="false"
            android:textColor="@color/novelero_bg"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No tienes una cuenta? "
            android:textColor="@color/novelero_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_ir_registro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:text="Regístrate"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
