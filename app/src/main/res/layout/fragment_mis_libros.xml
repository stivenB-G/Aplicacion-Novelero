<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Saludo (Igual a Biblioteca para consistencia) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/saludo_usuario"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            tools:text="Hola, Alex" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/estadistica_semanal"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="14sp" />

        <!-- Pestañas (Igual a Biblioteca) -->
        <com.google.android.material.tabs.TabLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@android:color/transparent"
            app:tabIndicatorColor="@color/white"
            app:tabIndicatorHeight="2dp"
            app:tabMode="fixed"
            app:tabSelectedTextColor="@color/white"
            app:tabTextColor="@color/novelero_text_secondary"
            app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Caption">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_favoritos" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_leer_despues" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_pausado" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_mis_libros" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Lista de Mis Obras -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <!-- Libro Publicado 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/novelero_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cv_portada_mia_1"
                            android:layout_width="80dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="@color/novelero_input_bg"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/cv_portada_mia_1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="El Eco de las Sombras"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Subido 2/1/2025 • 24 vistas esta semana"
                                android:textColor="@color/novelero_text_secondary"
                                android:textSize="13sp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Botones de Acción -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/fondo_chip_categoria"
                            android:backgroundTint="@color/novelero_input_bg"
                            android:drawableStart="@drawable/ic_ojo"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_ver"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:drawableTint="@color/novelero_accent" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/fondo_chip_categoria"
                            android:backgroundTint="@color/novelero_input_bg"
                            android:drawableStart="@drawable/ic_editorial"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_editar"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:drawableTint="@color/white" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1.2"
                            android:background="@drawable/fondo_chip_categoria"
                            android:backgroundTint="@color/novelero_input_bg"
                            android:drawableStart="@drawable/ic_borrar"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_eliminar"
                            android:textColor="@color/novelero_danger"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:drawableTint="@color/novelero_danger" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Borrador -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/novelero_card"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cv_portada_mia_borrador"
                            android:layout_width="80dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="@color/novelero_input_bg">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="28dp"
                                android:src="@drawable/ic_galeria"
                                app:tint="@color/novelero_muted"
                                android:contentDescription="@null" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/cv_portada_mia_borrador"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Borrador Sin Título"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold|italic"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Última edición hace 2 días"
                                android:textColor="@color/novelero_text_secondary"
                                android:textSize="13sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/fondo_chip_categoria"
                                android:backgroundTint="@color/novelero_bg"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="2dp"
                                android:text="@string/label_borrador"
                                android:textColor="@color/novelero_text_secondary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                tools:ignore="SmallSp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@drawable/fondo_chip_categoria"
                            android:backgroundTint="@color/novelero_input_bg"
                            android:drawableStart="@drawable/ic_ojo"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_ver"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:drawableTint="@color/novelero_accent" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/fondo_chip_categoria"
                            android:backgroundTint="@color/novelero_input_bg"
                            android:drawableStart="@drawable/ic_editorial"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_editar"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:drawableTint="@color/white" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1.2"
                            android:background="@drawable/fondo_chip_categoria"
                            android:backgroundTint="@color/novelero_input_bg"
                            android:drawableStart="@drawable/ic_borrar"
                            android:drawablePadding="8dp"
                            android:paddingHorizontal="12dp"
                            android:text="@string/btn_eliminar"
                            android:textColor="@color/novelero_danger"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:drawableTint="@color/novelero_danger" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón Subir Nueva Obra (Dashed border) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="40dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/fondo_subida"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/fondo_chip_categoria"
                        android:backgroundTint="@color/novelero_input_bg"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/novelero_accent"
                        android:textSize="24sp"
                        tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/subir_nueva_obra"
                        android:textColor="@color/novelero_accent"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Espaciador final para evitar que el contenido quede oculto tras el BottomNav -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
