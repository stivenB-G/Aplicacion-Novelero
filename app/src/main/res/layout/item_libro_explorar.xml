<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/novelero_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Portada del Libro (Cargada desde URL de Supabase) -->
        <androidx.cardview.widget.CardView
            android:layout_width="90dp"
            android:layout_height="125dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/novelero_input_bg">

            <ImageView
                android:id="@+id/iv_portada_item"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@color/novelero_bg"
                android:contentDescription="@null" />
        </androidx.cardview.widget.CardView>

        <!-- Información del Libro -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_titulo_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="El Ascenso del Rey Sombra" />

            <TextView
                android:id="@+id/tv_autor_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/novelero_text_secondary"
                android:textSize="14sp"
                tools:text="Por A. K. Vancier" />

            <!-- Precio y Género -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_precio_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/fondo_boton_principal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/novelero_bg"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    tools:text="50 CRÉDITOS" />

                <TextView
                    android:id="@+id/tv_genero_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/fondo_chip_categoria"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/novelero_text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    tools:text="FANTASÍA" />
            </LinearLayout>

            <!-- Stats (Rating y Vistas) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_estrella"
                    app:tint="@color/novelero_primary"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_rating_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/novelero_muted"
                    android:textSize="11sp"
                    tools:text="4.9" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_ojo"
                    app:tint="@color/novelero_muted"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/tv_vistas_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/novelero_muted"
                    android:textSize="11sp"
                    tools:text="1.2M" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
