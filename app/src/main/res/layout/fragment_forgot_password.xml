<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    android:padding="24dp">

    <!-- TITULO -->
    <TextView
        android:id="@+id/tvTitleRecover"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/recover_password_title"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="60dp"/>

    <!-- SUB -->
    <TextView
        android:id="@+id/tvSubtitleRecover"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/recover_password_subtitle"
        android:textColor="@color/novelero_text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitleRecover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- EMAIL -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilRecoverEmail"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="42dp"
        app:boxBackgroundColor="@color/novelero_input_bg"
        app:boxCornerRadiusBottomEnd="18dp"
        app:boxCornerRadiusBottomStart="18dp"
        app:boxCornerRadiusTopEnd="18dp"
        app:boxCornerRadiusTopStart="18dp"
        app:boxStrokeColor="@color/novelero_primary"
        app:hintTextColor="@color/novelero_text_secondary"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitleRecover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etRecoverEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/correo_electronico"
            android:inputType="textEmailAddress"
            android:textColor="@color/white"
            android:textColorHint="@color/novelero_muted"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- BOTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRecover"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginTop="30dp"
        android:text="@string/btn_enviar_instrucciones"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="@color/novelero_primary"
        app:cornerRadius="18dp"
        app:layout_constraintTop_toBottomOf="@id/tilRecoverEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- MENSAJE -->
    <TextView
        android:id="@+id/tvRecoverInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/recover_password_info"
        android:textColor="@color/novelero_text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnRecover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
