<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- Portada de Fondo -->
            <ImageView
                android:id="@+id/iv_portada_fondo"
                android:layout_width="match_parent"
                android:layout_height="450dp"
                android:scaleType="centerCrop"
                android:src="@color/novelero_card"
                android:contentDescription="@string/app_name"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Degradado para legibilidad -->
            <View
                android:layout_width="match_parent"
                android:layout_height="450dp"
                android:background="@drawable/fondo_degradado_libro"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Contenido -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginTop="300dp">

                <!-- Tags -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    tools:ignore="UseCompoundDrawables">

                    <TextView
                        android:id="@+id/tv_tag_genero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/fondo_chip_categoria"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="FANTASÍA"
                        android:textAllCaps="true"
                        android:textColor="@color/novelero_accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:ignore="SmallSp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/fondo_chip_categoria"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="ACCIÓN"
                        android:textColor="@color/novelero_accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText,SmallSp" />
                </LinearLayout>

                <!-- Título -->
                <TextView
                    android:id="@+id/tv_titulo_detalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Sombras del\nDestino Eterno"
                    android:textColor="@color/white"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:lineHeight="40sp"
                    tools:ignore="HardcodedText" />

                <!-- Autor -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/novelero_input_bg"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/icono_perfil"
                            android:padding="4dp"
                            android:contentDescription="@null"
                            app:tint="@color/novelero_text_secondary" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tv_autor_detalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Haruki Tanaka"
                        android:textColor="@color/novelero_text_secondary"
                        android:textSize="14sp"
                        tools:ignore="HardcodedText" />
                </LinearLayout>

                <!-- Estadísticas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:orientation="horizontal">

                    <!-- Rating -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardBackgroundColor="@color/novelero_card"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_estrella"
                                android:contentDescription="@null"
                                app:tint="@color/novelero_primary" />
                            <TextView
                                android:id="@+id/tv_rating_detalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="4.9"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RATING"
                                android:textColor="@color/novelero_muted"
                                android:textSize="9sp"
                                tools:ignore="HardcodedText,SmallSp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Caps -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        app:cardBackgroundColor="@color/novelero_card"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_libro_abierto"
                                android:contentDescription="@null"
                                app:tint="@color/novelero_accent" />
                            <TextView
                                android:id="@+id/tv_caps_detalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="342"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CAPS"
                                android:textColor="@color/novelero_muted"
                                android:textSize="9sp"
                                tools:ignore="HardcodedText,SmallSp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Vistas -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        app:cardBackgroundColor="@color/novelero_card"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_ojo"
                                android:contentDescription="@null"
                                app:tint="@color/novelero_accent" />
                            <TextView
                                android:id="@+id/tv_vistas_detalle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="1.2M"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="VISTAS"
                                android:textColor="@color/novelero_muted"
                                android:textSize="9sp"
                                tools:ignore="HardcodedText,SmallSp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Sinopsis -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:text="@string/label_sinopsis"
                    android:textColor="@color/novelero_accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_sinopsis_detalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineHeight="24sp"
                    android:text="@string/lorem_ipsum"
                    android:textColor="@color/novelero_text_secondary"
                    android:textSize="15sp"
                    tools:text="En un mundo donde las sombras cobran vida..." />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Botón Flotante "Agregar al carrito" -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btn_agregar_carrito"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="32dp"
            tools:ignore="UseCompoundDrawables">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_carrito"
                android:contentDescription="@null"
                app:tint="@color/novelero_bg" />

            <TextView
                android:id="@+id/tv_btn_precio_detalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Agregar al carrito"
                android:textColor="@color/novelero_bg"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>
