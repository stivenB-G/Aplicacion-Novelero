<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    tools:context=".ui.auth.RecuperarContrasenaActivity">

    <!-- Logo y Título -->
    <LinearLayout
        android:id="@+id/ll_logo_recuperar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logosplash"
            android:contentDescription="@string/app_name" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_name"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tarjeta de Recuperación -->
    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="@color/novelero_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="23dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_logo_recuperar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_recuperar"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/instrucciones_recuperar"
                android:textColor="@color/novelero_text_secondary"
                android:textSize="14sp"
                android:lineHeight="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/correo_electronico"
                android:textColor="@color/novelero_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Input Correo con Icono -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/fondo_campo_texto"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/iv_email_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_dialog_email"
                    android:contentDescription="@null"
                    app:tint="@color/novelero_text_secondary" />

                <EditText
                    android:id="@+id/et_correo_recuperar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/iv_email_icon"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/hint_correo_ejemplo"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress"
                    android:textColor="@color/white"
                    android:textColorHint="@color/novelero_muted"
                    android:textSize="15sp" />
            </RelativeLayout>

            <!-- Botón Enviar -->
            <Button
                android:id="@+id/btn_enviar_instrucciones"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/fondo_boton_principal"
                android:text="@string/btn_enviar_instrucciones"
                android:textAllCaps="false"
                android:textColor="@color/novelero_bg"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <!-- Enlace Volver -->
            <TextView
                android:id="@+id/tv_volver_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                android:text="@string/volver_inicio_sesion"
                android:textColor="@color/novelero_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Indicador de Progreso Inferior -->
    <View
        android:layout_width="120dp"
        android:layout_height="3dp"
        android:layout_marginBottom="24dp"
        android:background="@color/novelero_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
