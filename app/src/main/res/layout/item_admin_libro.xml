<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/novelero_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Portada del Libro -->
        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="110dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/novelero_input_bg">

            <ImageView
                android:id="@+id/iv_portada_admin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:src="@color/novelero_primary"
                android:contentDescription="@null" />
        </androidx.cardview.widget.CardView>

        <!-- Información -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_titulo_admin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Sombras del Reino" />

            <TextView
                android:id="@+id/tv_autor_admin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/novelero_text_secondary"
                android:textSize="13sp"
                tools:text="Autor: Diana Jimenez" />

            <TextView
                android:id="@+id/tv_ventas_admin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/novelero_accent"
                android:textStyle="bold"
                android:textSize="13sp"
                tools:text="Ventas: 240" />

            <!-- Botones de Acción -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_editar_admin"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/btn_editar"
                    android:textAllCaps="false"
                    android:textColor="@color/novelero_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_eliminar_admin"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/btn_eliminar"
                    android:textAllCaps="false"
                    android:textColor="@color/novelero_danger"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
