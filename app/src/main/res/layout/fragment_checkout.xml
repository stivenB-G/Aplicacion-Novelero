<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/novelero_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/pasarela_de_pago"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/finaliza_tu_compra_de_forma_segura"
            android:textColor="@color/novelero_text_secondary"
            android:textSize="14sp" />

        <!-- Sección de Métodos de Pago -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/novelero_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/seleccione_m_todo_de_pago"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_anadir_metodo"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="+ AÑADIR"
                        android:textAllCaps="false"
                        android:textColor="@color/novelero_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="16dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        app:backgroundTint="@color/novelero_input_bg"
                        app:cornerRadius="10dp"
                        app:rippleColor="@color/novelero_primary"
                        tools:ignore="HardcodedText" />
                </RelativeLayout>

                <!-- RecyclerView para métodos de pago -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_metodos_pago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_metodo_pago"
                    tools:itemCount="2" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón Pagar -->
        <Button
            android:id="@+id/btn_finalizar_pago"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/fondo_boton_principal"
            android:text="@string/pagar_ahora_libro"
            android:textAllCaps="false"
            android:textColor="@color/novelero_bg"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
